# Create .gitignore
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json

# Logs
logs/
*.log

# Uploads
uploads/
!uploads/.gitkeep

# Database
*.db
*.sqlite
*.sqlite3

# Alembic
migrations/versions/*.py
!migrations/versions/__init__.py

# Coverage
.coverage
coverage.xml
*.cover
EOF