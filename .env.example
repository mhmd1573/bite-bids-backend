# ============================================
# BiteBids Backend - Environment Variables
# ============================================

# ============================================
# APPLICATION
# ============================================
APP_NAME=BiteBids API
APP_VERSION=1.0.0
DEBUG=True
ENV=development

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bitebids

# ============================================
# SECURITY
# ============================================
# JWT Secret - Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# Encryption Key - Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-change-this-in-production

# ============================================
# URLS
# ============================================
# Frontend application URL
FRONTEND_URL=http://localhost:3000

# Backend API base URL
BASE_URL=http://localhost:8001

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://bitebids.com

# ============================================
# EMAIL (SMTP)
# ============================================
# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-or-smtp-key
EMAIL_FROM=your-email@gmail.com
ADMIN_EMAIL=admin@bitebids.com

# ============================================
# STRIPE PAYMENTS
# ============================================
# Stripe API Keys (Get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_here

# Stripe Webhook Secret (Get from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Connect Webhook Secret (Separate from regular webhook)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# CLOUDFLARE R2 STORAGE
# ============================================
# Cloudflare R2 Configuration (S3-compatible)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=bitebids-projects

# ============================================
# OPENAI
# ============================================
# OpenAI API Key for content moderation
OPENAI_API_KEY=sk_your_openai_key_here

# Moderation fail mode: 'fail_closed' or 'fail_open'
MODERATION_FAIL_MODE=fail_closed

# ============================================
# GITHUB INTEGRATION
# ============================================
# GitHub OAuth (Get from https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# GitHub Personal Access Token (for API calls)
GITHUB_TOKEN=ghp_your_github_token_here

# ============================================
# GOOGLE OAUTH
# ============================================
# Google OAuth (Get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# 2CHECKOUT (Legacy - Optional)
# ============================================
CHECKOUT_MERCHANT_CODE=your-merchant-code
CHECKOUT_SECRET_KEY=your-secret-key
CHECKOUT_PUBLISHABLE_KEY=your-publishable-key
CHECKOUT_PRIVATE_KEY=your-private-key
CHECKOUT_INS_SECRET_WORD=your-ins-secret-word
CHECKOUT_BUY_LINK_SECRET_WORD=your-buy-link-secret-word
CHECKOUT_ENVIRONMENT=sandbox

# ============================================
# IMGBB (Image Hosting)
# ============================================
# ImgBB API Key for image uploads
IMGBB_API_KEY=your-imgbb-api-key
IMGBB_UPLOAD_URL=https://api.imgbb.com/1/upload

# ============================================
# PLATFORM FEES
# ============================================
# Platform commission percentage (e.g., 6 = 6%)
PLATFORM_FEE_PERCENTAGE=6

# Platform fixed fee per transaction
PLATFORM_FIXED_FEE=30

# Fee for posting a project
PROJECT_POSTING_FEE=0.99

# ============================================
# FILE UPLOADS
# ============================================
# Maximum file upload size in bytes (5MB default)
MAX_UPLOAD_SIZE=5242880

# Upload directories (relative to project root)
UPLOAD_DIR=uploads/chat_files
PROJECT_IMAGES_DIR=uploads/project_images

# Allowed image extensions
ALLOWED_IMAGE_EXTENSIONS=.png,.jpg,.jpeg

# ============================================
# LOGGING
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# RATE LIMITING
# ============================================
# Rate limiting settings
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# DEVELOPMENT
# ============================================
# Enable/disable auto-reload in development
RELOAD=True

# Port for the development server
PORT=8001